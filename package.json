{
	"name": "mariannecottage",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "npm run smui-theme-light && npm run smui-theme-dark && svelte-kit sync || echo ''",
		"smui-theme-light": "smui-theme compile static/smui.css -i src/theme",
		"smui-theme-dark": "smui-theme compile static/smui-dark.css -i src/theme/dark",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/leaflet": "^1.9.21",
		"autoprefixer": "^10.4.27",
		"postcss": "^8.5.8",
		"sass": "^1.98.0",
		"smui-theme": "^8.0.3",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@smui/button": "^8.0.0-alpha.0",
		"@smui/card": "^8.0.0-alpha.0",
		"@smui/chips": "^8.0.0-alpha.0",
		"@smui/common": "^8.0.0-alpha.0",
		"@smui/data-table": "^8.0.0-alpha.0",
		"@smui/dialog": "^8.0.0-alpha.0",
		"@smui/drawer": "^8.0.0-alpha.0",
		"@smui/fab": "^8.0.0-alpha.0",
		"@smui/icon-button": "^8.0.0-alpha.0",
		"@smui/layout-grid": "^8.0.0-alpha.0",
		"@smui/list": "^8.0.0-alpha.0",
		"@smui/select": "^8.0.0-alpha.0",
		"@smui/tab": "^8.0.0-alpha.0",
		"@smui/tab-bar": "^8.0.0-alpha.0",
		"@smui/textfield": "^8.0.0-alpha.0",
		"@smui/top-app-bar": "^8.0.0-alpha.0",
		"@supabase/supabase-js": "^2.99.3",
		"ical.js": "^2.2.1",
		"leaflet": "^1.9.4"
	}
}
